---
import BaseHead from "@/components/BaseHead.astro";
import Footer from "@/components/layout/Footer.astro";
import Header from "@/components/layout/Header.astro";
import SkipLink from "@/components/SkipLink.astro";
import ThemeProvider from "@/components/ThemeProvider.astro";
import { siteConfig } from "@/site.config";
import type { SiteMeta } from "@/types";

interface Props {
	meta: SiteMeta;
}

const {
	meta: { articleDate, articleModifiedDate, description = siteConfig.description, ogImage, title },
} = Astro.props;
---

<html class="scroll-smooth" lang={siteConfig.lang}>
	<head>
		<BaseHead
			articleDate={articleDate}
			articleModifiedDate={articleModifiedDate}
			description={description}
			ogImage={ogImage}
			title={title}
		/>
		<ThemeProvider />
	</head>
	<body
		class="bg-global-bg text-global-text mx-auto flex min-h-screen max-w-3xl flex-col px-4 pt-16 font-mono text-sm font-normal antialiased sm:px-8"
	>
		<SkipLink />
		<Header />
		<main id="main">
			<slot />
		</main>
		<Footer />
		<script is:inline type="speculationrules">
			{
				"prefetch": [
					{
						"where": {
							"selector_matches": "a[href^='/']:not([href$='.xml']):not([href*='/rss'])"
						},
						"eagerness": "moderate"
					}
				],
				"prerender": [
					{
						"where": {
							"selector_matches": "a[href^='/posts/'],a[href^='/notes/'],a[href^='/work/'],a[href^='/about/']"
						},
						"eagerness": "conservative"
					}
				]
			}
		</script>
	</body>
</html>
