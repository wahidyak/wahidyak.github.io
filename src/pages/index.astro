---
import SocialList from "@/components/SocialList.astro";
import PageLayout from "@/layouts/Base.astro";
import { siteConfig } from "@/site.config";

const meta = {
	description: siteConfig.description,
	ogImage: "/img/yakubu.JPG",
	title: "Home",
};
---

<PageLayout meta={meta}>
	<section class="flex flex-col gap-8 sm:flex-row sm:items-start sm:gap-10">
		<img
			alt="Abdul-Wahid Yakubu"
			class="border-accent/30 ring-accent/20 h-auto w-full max-w-[220px] shrink-0 rounded-lg border object-cover shadow-md ring-2 sm:max-w-[260px]"
			decoding="async"
			height="500"
			loading="eager"
			src="/img/IMG_4281.JPG"
			width="400"
		/>
		<div class="min-w-0 flex-1">
			<h1 class="title mb-6">Hi, I’m Abdul-Wahid.</h1>
			<p class="mb-4">
				I work at the intersection of <strong class="text-global-text">platform engineering</strong>,{" "}
				<strong class="text-global-text">data &amp; ML</strong>, and{" "}
				<strong class="text-global-text">networking</strong>—currently pursuing an MEng at the University of
				Victoria while building automated container stacks and CI/CD for Canada’s national astronomy cloud
				(CANFAR) at the NRC.
			</p>
			<p class="mb-6">
				<a class="cactus-link font-semibold" href="/Abdul-Wahid-Yakubu-Resume.pdf" download
					>Download résumé (PDF)</a
				>
				<span class="text-muted"> · </span>
				<a class="cactus-link font-semibold" href="/about/">About me</a>
				<span class="text-muted"> · </span>
				<a class="cactus-link font-semibold" href="/work/">Selected work</a>
			</p>
			<SocialList />
		</div>
	</section>

	<section class="mt-16">
		<h2 class="title mb-8 text-xl">What I do</h2>
		<ul class="space-y-8" role="list">
			<li>
				<h3 class="text-accent mb-2 font-semibold">Containers &amp; DevOps</h3>
				<p class="text-muted">
					Layered container images, GPU-ready scientific environments, and CI/CD pipelines with scheduled
					security rebuilds—so researchers get reliable access without manual dependency drift.
				</p>
			</li>
			<li>
				<h3 class="text-accent mb-2 font-semibold">Data &amp; machine learning</h3>
				<p class="text-muted">
					From executive dashboards and statistical validation to deep learning for GPS spoofing detection
					(1D CNNs, cross-validation, domain-shift mitigation)—turning raw signals into decisions.
				</p>
			</li>
			<li>
				<h3 class="text-accent mb-2 font-semibold">Networking &amp; security</h3>
				<p class="text-muted">
					CCNA/CCNP-level switching and routing, plus hands-on digital forensics (memory, disk, mobile) and
					timeline-driven threat analysis.
				</p>
			</li>
		</ul>
	</section>
</PageLayout>
